# Database Configuration
ConnectionStrings__DefaultConnection=Server=localhost,1433;Database=ExpenseTrackerDb;User Id=sa;Password=YOUR_SA_PASSWORD;TrustServerCertificate=True;

# JWT Configuration
Jwt__Secret=your-secret-key-at-least-32-characters-long-for-hs256
Jwt__Issuer=ExpenseTrackerApi
Jwt__Audience=ExpenseTrackerClient
Jwt__ExpiryMinutes=1440

# AI/LLM Configuration (Groq)
OpenAI__ApiKey=gsk_your_groq_api_key_here
OpenAI__Model=openai/gpt-oss-20b
OpenAI__ResponsesEndpoint=https://api.groq.com/openai/v1/responses

# Azure Blob Storage
AzureBlob__ConnectionString=DefaultEndpointsProtocol=https;AccountName=youraccountname;AccountKey=youraccountkey;EndpointSuffix=core.windows.net
AzureBlob__ContainerName=receipts

# Email Configuration
Email__SmtpHost=smtp.gmail.com
Email__SmtpPort=587
Email__SenderEmail=your-email@gmail.com
Email__SenderPassword=your-app-specific-password
Email__EnableSSL=true

# Application Settings
ASPNETCORE_ENVIRONMENT=Development
ASPNETCORE_URLS=https://localhost:5001;http://localhost:5000

# CORS Configuration (comma-separated)
AllowedOrigins=http://localhost:3000,http://localhost:5173,https://app.example.com

# Security
RequireHttps=false
